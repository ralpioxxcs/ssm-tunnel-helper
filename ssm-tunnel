#!/usr/bin/env bash
# ssm-tunnel: AWS SSM port-forwarding daemon with auto-reconnect
#
# Usage: ssm-tunnel start --target i-xxxx --local-port 5432 --remote-port 5432 [OPTIONS]
#        ssm-tunnel stop | status | logs [-f] | restart

set -euo pipefail

_src="${BASH_SOURCE[0]}"
while [[ -L "$_src" ]]; do
    _dir="$(cd "$(dirname "$_src")" && pwd)"
    _src="$(readlink "$_src")"
    [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
SCRIPT_PATH="$(cd "$(dirname "$_src")" && pwd)/$(basename "$_src")"
unset _src _dir
PID_FILE="${XDG_RUNTIME_DIR:-/tmp}/ssm-tunnel.pid"
LOG_DIR="${HOME}/.local/log"
LOG_FILE="${LOG_DIR}/ssm-tunnel.log"
CHECK_INTERVAL=10  # seconds between liveness checks
TOKEN_CHECK_INTERVAL=60  # seconds between token validity checks

# ─── Daemon entry point (internal) ──────────────────────────────────────────
if [[ "${1:-}" == "__daemon__" ]]; then
    shift
    TARGET="$1"
    LOCAL_PORT="$2"
    REMOTE_PORT="$3"
    REMOTE_HOST="$4"
    REGION="$5"
    AWS_ACCESS_KEY_ID="$6"
    AWS_SECRET_ACCESS_KEY="$7"
    AWS_SESSION_TOKEN="$8"
    export AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN
    export AWS_DEFAULT_REGION="$REGION"

    SSM_PID=""
    LAST_TOKEN_CHECK=0

    log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"; }

    check_token() {
        aws sts get-caller-identity --output text >/dev/null 2>&1
    }

    start_session() {
        aws ssm start-session \
            --target "$TARGET" \
            --document-name AWS-StartPortForwardingSessionToRemoteHost \
            --parameters "{\"host\":[\"$REMOTE_HOST\"],\"portNumber\":[\"$REMOTE_PORT\"],\"localPortNumber\":[\"$LOCAL_PORT\"]}" \
            >/dev/null 2>&1 &
        echo $!
    }

    cleanup() {
        log "Shutting down (signal received)"
        if [[ -n "${SSM_PID:-}" ]] && kill -0 "$SSM_PID" 2>/dev/null; then
            kill "$SSM_PID" 2>/dev/null
            wait "$SSM_PID" 2>/dev/null || true
        fi
        rm -f "$PID_FILE"
        exit 0
    }
    trap cleanup TERM INT

    log "Daemon started"
    log "  Target      : $TARGET"
    log "  Tunnel      : localhost:$LOCAL_PORT -> $REMOTE_HOST:$REMOTE_PORT"
    log "  Region      : $REGION"

    # Initial token check
    if ! check_token; then
        log "ERROR: AWS credentials are invalid or expired. Aborting."
        rm -f "$PID_FILE"
        exit 1
    fi
    LAST_TOKEN_CHECK=$(date +%s)

    while true; do
        NOW=$(date +%s)

        # Periodic token validity check
        if (( NOW - LAST_TOKEN_CHECK >= TOKEN_CHECK_INTERVAL )); then
            if ! check_token; then
                log "AWS token expired. Stopping daemon."
                [[ -n "${SSM_PID:-}" ]] && kill "$SSM_PID" 2>/dev/null || true
                rm -f "$PID_FILE"
                exit 0
            fi
            LAST_TOKEN_CHECK=$NOW
        fi

        # Start or restart the SSM session if it's not running
        if [[ -z "${SSM_PID:-}" ]] || ! kill -0 "$SSM_PID" 2>/dev/null; then
            if [[ -n "${SSM_PID:-}" ]]; then
                wait "$SSM_PID" 2>/dev/null || true
                log "Session (PID $SSM_PID) ended. Reconnecting..."
            else
                log "Starting SSM session..."
            fi

            SSM_PID="$(start_session)"
            log "Session started (PID $SSM_PID)"
        fi

        sleep "$CHECK_INTERVAL"
    done
fi

# ─── Helper functions ────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

err()  { echo -e "${RED}Error:${NC} $*" >&2; }
info() { echo -e "${GREEN}»${NC} $*"; }
warn() { echo -e "${YELLOW}Warning:${NC} $*"; }

usage() {
    cat <<EOF
ssm-tunnel — AWS SSM port-forwarding daemon with auto-reconnect

USAGE
    ssm-tunnel start [OPTIONS]    Start the tunnel daemon
    ssm-tunnel stop               Stop the running daemon
    ssm-tunnel restart [OPTIONS]  Restart the daemon
    ssm-tunnel status             Show daemon status
    ssm-tunnel logs [-f]          Show logs (use -f to follow)

START OPTIONS
    --target        <instance-id>   EC2 instance ID to connect through (required)
    --local-port    <port>          Local port to listen on (required)
    --remote-port   <port>          Port on the remote host (required)
    --remote-host   <host>          Remote host reachable from the instance
                                    (default: localhost — the instance itself)
    --region        <region>        AWS region (default: \$AWS_DEFAULT_REGION or us-east-1)

    --access-key    <key>           AWS_ACCESS_KEY_ID     (default: env var)
    --secret-key    <key>           AWS_SECRET_ACCESS_KEY (default: env var)
    --session-token <token>         AWS_SESSION_TOKEN     (default: env var)

EXAMPLES
    # Forward local 5432 to an RDS endpoint through a bastion
    ssm-tunnel start \\
        --target i-0abc1234def56789 \\
        --local-port 5432 \\
        --remote-host my-db.cluster-xyz.us-east-1.rds.amazonaws.com \\
        --remote-port 5432

    # Use explicit credentials
    ssm-tunnel start \\
        --target i-0abc1234def56789 \\
        --local-port 3306 --remote-port 3306 \\
        --access-key ASIA... --secret-key wJalr... --session-token IQoJ...

    ssm-tunnel status
    ssm-tunnel logs -f
    ssm-tunnel stop

NOTES
    PID file : $PID_FILE
    Log file : $LOG_FILE
EOF
}

daemon_running() {
    [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

# ─── Commands ────────────────────────────────────────────────────────────────
cmd_stop() {
    if ! daemon_running; then
        warn "Daemon is not running."
        return 0
    fi
    local pid
    pid="$(cat "$PID_FILE")"
    info "Stopping daemon (PID $pid)..."
    kill "$pid"
    local waited=0
    while kill -0 "$pid" 2>/dev/null; do
        sleep 1
        (( waited++ ))
        if (( waited >= 10 )); then
            warn "Daemon did not stop cleanly; sending SIGKILL."
            kill -9 "$pid" 2>/dev/null || true
            break
        fi
    done
    rm -f "$PID_FILE"
    info "Daemon stopped."
}

cmd_status() {
    if daemon_running; then
        local pid
        pid="$(cat "$PID_FILE")"
        info "Daemon is running (PID $pid)"
        echo ""
        # Show last few log lines for context
        if [[ -f "$LOG_FILE" ]]; then
            echo "Recent log:"
            tail -n 10 "$LOG_FILE" | sed 's/^/  /'
        fi
    else
        warn "Daemon is not running."
        if [[ -f "$LOG_FILE" ]]; then
            echo ""
            echo "Last log entries:"
            tail -n 5 "$LOG_FILE" | sed 's/^/  /'
        fi
        return 1
    fi
}

cmd_logs() {
    if [[ ! -f "$LOG_FILE" ]]; then
        warn "No log file found at $LOG_FILE"
        return 1
    fi
    if [[ "${1:-}" == "-f" ]]; then
        tail -f "$LOG_FILE"
    else
        cat "$LOG_FILE"
    fi
}

cmd_start() {
    # Parse options
    local target="" local_port="" remote_port="" remote_host="localhost"
    local region="${AWS_DEFAULT_REGION:-us-east-1}"
    local access_key="${AWS_ACCESS_KEY_ID:-}"
    local secret_key="${AWS_SECRET_ACCESS_KEY:-}"
    local session_token="${AWS_SESSION_TOKEN:-}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --target)        target="$2";        shift 2 ;;
            --local-port)    local_port="$2";    shift 2 ;;
            --remote-port)   remote_port="$2";   shift 2 ;;
            --remote-host)   remote_host="$2";   shift 2 ;;
            --region)        region="$2";        shift 2 ;;
            --access-key)    access_key="$2";    shift 2 ;;
            --secret-key)    secret_key="$2";    shift 2 ;;
            --session-token) session_token="$2"; shift 2 ;;
            -h|--help)       usage; exit 0 ;;
            *) err "Unknown option: $1"; usage; exit 1 ;;
        esac
    done

    # Validate required args
    local missing=()
    [[ -z "$target" ]]       && missing+=("--target")
    [[ -z "$local_port" ]]   && missing+=("--local-port")
    [[ -z "$remote_port" ]]  && missing+=("--remote-port")
    [[ -z "$access_key" ]]   && missing+=("--access-key / AWS_ACCESS_KEY_ID")
    [[ -z "$secret_key" ]]   && missing+=("--secret-key / AWS_SECRET_ACCESS_KEY")
    [[ -z "$session_token" ]] && missing+=("--session-token / AWS_SESSION_TOKEN")

    if [[ ${#missing[@]} -gt 0 ]]; then
        err "Missing required arguments:"
        for m in "${missing[@]}"; do echo "    $m"; done
        exit 1
    fi

    # Validate port numbers
    for port in "$local_port" "$remote_port"; do
        if ! [[ "$port" =~ ^[0-9]+$ ]] || (( port < 1 || port > 65535 )); then
            err "Invalid port: $port"
            exit 1
        fi
    done

    if daemon_running; then
        err "Daemon is already running (PID $(cat "$PID_FILE")). Use 'ssm-tunnel stop' first."
        exit 1
    fi

    # Check dependencies
    if ! command -v aws &>/dev/null; then
        err "AWS CLI not found. Install it: https://docs.aws.amazon.com/cli/latest/userguide/getting-started-install.html"
        exit 1
    fi

    mkdir -p "$LOG_DIR"

    info "Starting SSM tunnel daemon..."
    echo "  Target      : $target"
    echo "  Tunnel      : localhost:$local_port -> $remote_host:$remote_port"
    echo "  Region      : $region"
    echo "  Log file    : $LOG_FILE"

    # Launch daemon as a detached subprocess that re-invokes this script
    nohup "$SCRIPT_PATH" __daemon__ \
        "$target" "$local_port" "$remote_port" "$remote_host" "$region" \
        "$access_key" "$secret_key" "$session_token" \
        >> "$LOG_FILE" 2>&1 &

    local daemon_pid=$!
    echo "$daemon_pid" > "$PID_FILE"

    # Brief pause to catch immediate failures (bad credentials, etc.)
    sleep 2
    if ! kill -0 "$daemon_pid" 2>/dev/null; then
        err "Daemon failed to start. Check logs: $LOG_FILE"
        rm -f "$PID_FILE"
        tail -n 5 "$LOG_FILE" | sed 's/^/  /' >&2
        exit 1
    fi

    info "Daemon started (PID $daemon_pid)"
}

cmd_restart() {
    if daemon_running; then
        cmd_stop
    fi
    cmd_start "$@"
}

# ─── Entry point ─────────────────────────────────────────────────────────────
COMMAND="${1:-}"
shift || true

case "$COMMAND" in
    start)   cmd_start "$@" ;;
    stop)    cmd_stop ;;
    restart) cmd_restart "$@" ;;
    status)  cmd_status ;;
    logs)    cmd_logs "$@" ;;
    -h|--help|help) usage ;;
    "")      usage; exit 1 ;;
    *)       err "Unknown command: $COMMAND"; usage; exit 1 ;;
esac
